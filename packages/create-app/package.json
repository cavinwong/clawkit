{
  "name": "create-clawkit-app",
  "version": "0.1.0",
  "description": "Create a new ClawKit agent application with a single command",
  "keywords": [
    "openclaw",
    "ai-agent",
    "clawkit",
    "create-app",
    "scaffold"
  ],
  "homepage": "https://github.com/cavinwong/clawkit#readme",
  "bugs": {
    "url": "https://github.com/cavinwong/clawkit/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cavinwong/clawkit.git",
    "directory": "packages/create-app"
  },
  "license": "MIT",
  "author": "ClawKit Contributors",
  "type": "module",
  "bin": {
    "create-clawkit-app": "./dist/bin/create.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.build.json",
    "dev": "pnpm exec tsc -p tsconfig.build.json --watch",
    "typecheck": "pnpm exec tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@openclaw-kit/cli": "workspace:*",
    "chalk": "^5.3.0",
    "enquirer": "^2.4.1"
  },
  "devDependencies": {
    "@types/node": ">=25.5.2",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

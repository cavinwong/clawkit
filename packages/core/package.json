{
  "name": "@openclaw-kit/core",
  "version": "0.1.0",
  "description": "Core SDK for building OpenClaw agent applications — types, manifest parsing, Tool SDK, and Memory ORM",
  "keywords": [
    "openclaw",
    "ai-agent",
    "clawkit",
    "sdk",
    "framework"
  ],
  "homepage": "https://github.com/cavinwong/clawkit#readme",
  "bugs": {
    "url": "https://github.com/cavinwong/clawkit/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cavinwong/clawkit.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "author": "ClawKit Contributors",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./tool": {
      "import": "./dist/tool/index.js",
      "types": "./dist/tool/index.d.ts"
    },
    "./memory": {
      "import": "./dist/memory/index.js",
      "types": "./dist/memory/index.d.ts"
    },
    "./manifest": {
      "import": "./dist/manifest/index.js",
      "types": "./dist/manifest/index.d.ts"
    },
    "./skill": {
      "import": "./dist/skill/index.js",
      "types": "./dist/skill/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.build.json",
    "dev": "pnpm exec tsc -p tsconfig.build.json --watch",
    "typecheck": "pnpm exec tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": ">=25.5.2",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
